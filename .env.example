APP_ENV=development
PORT=8080

# Database (PostgreSQL for production, SQLite for development)
DATABASE_URL=postgres://user:password@localhost:5432/gidana_db
# Or for SQLite (dev): leave DATABASE_URL empty and set DB_PATH
DB_PATH=gidana_dev.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=72

# File uploads
UPLOAD_DIR=./uploads/properties
MAX_UPLOAD_SIZE_MB=5

# Supabase Config
SUPABASE_URL=https://you-supabase-url.supabase.co
SUPABASE_KEY=your-supabase-key
SUPABASE_BUCKET=properties

# CORS
# React Native native (iOS/Android) bypasses CORS entirely — no entry needed.
# Add web origins below (Expo web, browser dev server, production frontend).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:8081
