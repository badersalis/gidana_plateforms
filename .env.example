APP_ENV=development
PORT=8080

# Database (PostgreSQL for production, SQLite for development)
DATABASE_URL=postgres://user:password@localhost:5432/gidana_db
# Or for SQLite (dev): leave DATABASE_URL empty and set DB_PATH
DB_PATH=gidana_dev.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=72

# File uploads
UPLOAD_DIR=./uploads/properties
MAX_UPLOAD_SIZE_MB=5

# Firebase (optional - for image storage)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_BUCKET=your-bucket.appspot.com
USE_FIREBASE=false

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006
